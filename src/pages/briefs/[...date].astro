---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadDailyBriefByDate, loadAllDailyBriefs, loadBriefsByDate } from '../../data/loader';
import { marked } from 'marked';

export function getStaticPaths() {
  const briefs = loadAllDailyBriefs();
  const paths = briefs.map((b) => ({
    params: { date: b.date },
    props: { date: b.date },
  }));
  paths.push({ params: { date: 'latest' }, props: { date: 'latest' } });
  return paths;
}

const { date } = Astro.props;

let resolvedDate = date;
if (date === 'latest') {
  const briefs = loadAllDailyBriefs();
  if (briefs.length > 0) {
    return Astro.redirect(`/briefs/${briefs[0].date}`);
  }
}

const dailyBrief = loadDailyBriefByDate(resolvedDate);
const collectorBriefs = loadBriefsByDate(resolvedDate);
const pageTitle = dailyBrief ? `Daily Brief — ${resolvedDate}` : `Briefs — ${resolvedDate}`;

// Parse top developments into individual items
function parseTopDevs(raw: string): string[] {
  return raw.split('\n').filter(l => l.startsWith('- ')).map(l => l.replace(/^- /, ''));
}

// Parse a section that uses ### subsections (narrative map, scenario spotlight)
function parseSubsections(raw: string): { title: string; content: string }[] {
  const parts = raw.split(/^### /m).filter(Boolean);
  return parts.map(part => {
    const lines = part.split('\n');
    const title = lines[0].trim();
    const content = lines.slice(1).join('\n').trim();
    return { title, content };
  });
}

// Parse divergence alerts into structured items
function parseDivergences(raw: string): { entity: string; detail: string }[] {
  return raw.split('\n').filter(l => l.startsWith('- **')).map(l => {
    const match = l.match(/^- \*\*([^*]+)\*\*:\s*(.+)$/);
    if (match) return { entity: match[1], detail: match[2] };
    return { entity: '', detail: l.replace(/^- /, '') };
  });
}

// Parse market signals into structured items
function parseMarketSignals(raw: string): { line: string; isNote: boolean }[] {
  return raw.split('\n').filter(l => l.trim()).map(l => ({
    line: l.replace(/^- /, ''),
    isNote: !l.startsWith('- **')
  }));
}

const topDevs = dailyBrief ? parseTopDevs(dailyBrief.topDevelopments) : [];
const narrativeSubs = dailyBrief ? parseSubsections(dailyBrief.narrativeMap) : [];
const divergences = dailyBrief ? parseDivergences(dailyBrief.divergenceAlerts) : [];
const marketLines = dailyBrief ? parseMarketSignals(dailyBrief.marketSignals) : [];
const scenarioSubs = dailyBrief ? parseSubsections(dailyBrief.scenarioSpotlight) : [];
const hasScenarioSubsections = scenarioSubs.length > 1;
---

<BaseLayout title={pageTitle} description={`Intelligence analysis for ${resolvedDate}`} breadcrumbs={[{ label: 'Briefs', href: '/briefs/latest' }, { label: resolvedDate }]}
  footerType="brief"
  footerUpdatedBy="Compiler"
  footerUpdatedAt={resolvedDate !== 'latest' ? resolvedDate : null}
  footerSourceCount={collectorBriefs.length}
>
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-100 mb-2">Daily Intelligence Brief</h1>
    <div class="flex items-center gap-3 text-gray-400">
      <span class="font-mono text-brand-400">{resolvedDate}</span>
      {dailyBrief && (
        <span class="text-xs text-gray-600">Generated {dailyBrief.generated.slice(11,16)} UTC</span>
      )}
      {dailyBrief && dailyBrief.confidenceFlag !== 'normal' && (
        <span class="text-xs px-2 py-0.5 rounded-full bg-amber-500/20 text-amber-400">{dailyBrief.confidenceFlag}</span>
      )}
    </div>
  </div>

  {dailyBrief ? (
    <div class="space-y-8">

      <!-- Top Developments -->
      <section>
        <h2 class="text-lg font-semibold text-gray-200 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          Top Developments
        </h2>
        <div class="space-y-3">
          {topDevs.map((dev, i) => (
            <div class="flex gap-4 p-4 rounded-xl bg-surface-raised border border-white/5">
              <span class="text-2xl font-bold text-brand-600/50 tabular-nums shrink-0 w-8 text-right">{i + 1}</span>
              <p class="text-sm text-gray-300 leading-relaxed" set:html={marked.parseInline(dev)} />
            </div>
          ))}
        </div>
      </section>

      <!-- Narrative Map -->
      {dailyBrief.narrativeMap && (
        <section>
          <h2 class="text-lg font-semibold text-gray-200 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
            Narrative Map
          </h2>
          <div class="space-y-4">
            {narrativeSubs.map((sub) => (
              <div class="rounded-xl bg-surface-raised border border-white/5 overflow-hidden">
                <div class="px-5 py-3 border-b border-white/5 bg-white/[0.02]">
                  <h3 class="text-sm font-semibold text-gray-200">{sub.title}</h3>
                </div>
                <div class="px-5 py-4 text-sm text-gray-400 leading-relaxed brief-content" set:html={marked.parse(sub.content)} />
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Divergence Alerts -->
      {dailyBrief.divergenceAlerts && (
        <section>
          <h2 class="text-lg font-semibold text-gray-200 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
            Divergence Alerts
          </h2>
          <div class="space-y-2">
            {divergences.map((d) => (
              <div class="flex gap-3 p-4 rounded-xl bg-surface-raised border border-white/5">
                <span class="text-xs font-semibold text-red-400/80 bg-red-500/10 px-2 py-1 rounded-md shrink-0 h-fit">{d.entity}</span>
                <p class="text-sm text-gray-400 leading-relaxed" set:html={marked.parseInline(d.detail)} />
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Market Signals -->
      {dailyBrief.marketSignals && (
        <section>
          <h2 class="text-lg font-semibold text-gray-200 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            Market Signals
          </h2>
          <div class="rounded-xl bg-surface-raised border border-white/5 overflow-hidden">
            <div class="divide-y divide-white/5">
              {marketLines.map((m) => (
                m.isNote ? (
                  <div class="px-5 py-3">
                    <p class="text-xs text-gray-500 italic">{m.line}</p>
                  </div>
                ) : (
                  <div class="px-5 py-3 flex items-center justify-between gap-4">
                    <p class="text-sm text-gray-300" set:html={marked.parseInline(m.line)} />
                  </div>
                )
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- Scenario Spotlight -->
      {dailyBrief.scenarioSpotlight && (
        <section>
          <h2 class="text-lg font-semibold text-gray-200 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            Scenario Spotlight
          </h2>
          <div class="rounded-xl bg-surface-raised border border-white/5 overflow-hidden">
            <div class="p-6 text-sm text-gray-300 leading-relaxed brief-content" set:html={marked.parse(dailyBrief.scenarioSpotlight)} />
          </div>
        </section>
      )}

      <!-- Cross-references -->
      <section class="space-y-3">
        <h2 class="text-lg font-semibold text-gray-200">Cross-References</h2>
        <div class="flex flex-wrap gap-2 text-xs">
          <span class="font-medium text-gray-400 mr-1 self-center">Events:</span>
          {dailyBrief.eventsAnalysed.map((slug) => (
            <a href={`/events/${slug}`} class="px-2.5 py-1 rounded-lg bg-white/5 text-gray-400 hover:text-brand-400 hover:bg-brand-500/10 transition-colors">{slug}</a>
          ))}
        </div>
        <div class="flex flex-wrap gap-2 text-xs">
          <span class="font-medium text-gray-400 mr-1 self-center">Entities:</span>
          {dailyBrief.entitiesReferenced.map((slug) => (
            <a href={`/entities/${slug}`} class="px-2.5 py-1 rounded-lg bg-white/5 text-gray-400 hover:text-blue-400 hover:bg-blue-500/10 transition-colors">{slug}</a>
          ))}
        </div>
        <div class="flex flex-wrap gap-2 text-xs">
          <span class="font-medium text-gray-400 mr-1 self-center">Markets:</span>
          {dailyBrief.marketsReferenced.map((slug) => (
            <a href={`/markets/${slug}`} class="px-2.5 py-1 rounded-lg bg-white/5 text-gray-400 hover:text-teal-400 hover:bg-teal-500/10 transition-colors">{slug}</a>
          ))}
        </div>
      </section>

      <!-- Methodology -->
      {dailyBrief.methodology && (
        <details>
          <summary class="text-sm text-gray-500 cursor-pointer hover:text-gray-400 transition-colors select-none py-2">
            Methodology &amp; data sources
          </summary>
          <div class="mt-2 p-4 rounded-xl bg-surface-raised border border-white/5">
            <div class="text-sm text-gray-500 leading-relaxed" set:html={marked.parse(dailyBrief.methodology)} />
          </div>
        </details>
      )}

      <!-- Source data -->
      {collectorBriefs.length > 0 && (
        <details>
          <summary class="flex items-center gap-2 text-sm text-gray-500 cursor-pointer hover:text-gray-400 transition-colors select-none py-2">
            <svg class="w-4 h-4 transition-transform details-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            Source data: {collectorBriefs.length} collector briefs
          </summary>
          <div class="mt-3 space-y-2">
            {collectorBriefs.map((cb) => {
              const timeFormatted = cb.time.length >= 4 ? `${cb.time.slice(0,2)}:${cb.time.slice(2,4)} UTC` : cb.time;
              return (
                <div class="px-4 py-3 rounded-lg bg-surface-raised border border-white/5 text-xs">
                  <span class="font-mono text-brand-400">{timeFormatted}</span>
                  <span class="text-gray-600 ml-2">{cb.summary ? cb.summary.slice(0, 150) + '...' : cb.title}</span>
                </div>
              );
            })}
          </div>
        </details>
      )}
    </div>
  ) : (
    <div class="p-6 rounded-xl bg-surface-raised border border-white/5">
      <p class="text-gray-500">No daily analysis available for this date.</p>
    </div>
  )}
</BaseLayout>

<style is:global>
  .brief-content ul { list-style: none; padding: 0; margin: 0; }
  .brief-content li { padding: 0.375rem 0; border-bottom: 1px solid rgba(255,255,255,0.03); }
  .brief-content li:last-child { border-bottom: none; }
  .brief-content li strong { color: rgb(209 213 219); }
  .brief-content h3 { font-size: 0.875rem; font-weight: 600; color: rgb(209 213 219); margin-top: 1rem; margin-bottom: 0.5rem; }
  .brief-content p { margin-bottom: 0.5rem; }
  .brief-content ol { padding-left: 1.25rem; }
  .brief-content ol li { list-style: decimal; padding: 0.25rem 0; border-bottom: none; }
</style>
