---
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/cards/EventCard.astro';
import MarketCard from '../components/cards/MarketCard.astro';
import EmptyState from '../components/shared/EmptyState.astro';
import { loadAllEvents, loadLatestBrief, loadLatestDailyBrief, loadMarketMovers, loadAllEntities, loadAllNarratives, loadAllMarkets } from '../data/loader';
import { formatVolume } from '../data/svg-chart';

const dailyBrief = loadLatestDailyBrief();
const brief = loadLatestBrief();
const devCount = brief?.topDevelopments 
  ? (brief.topDevelopments.match(/^### /gm) || []).length 
  : 0;
const movers = loadMarketMovers();
const events = loadAllEvents();
const entities = loadAllEntities();
const narratives = loadAllNarratives();
const markets = loadAllMarkets();

const recentEvents = events
  .filter((e) => e.timeline.length > 0)
  .slice(0, 7);

const topMarkets = movers.topGeoMarkets.slice(0, 5);
---

<BaseLayout title="Signal Intelligence Wiki" description="Real-time geopolitical event tracking, prediction market analysis, and narrative intelligence">
  <div class="mb-10">
    <div class="flex items-center gap-3 mb-2">
      <div class="w-10 h-10 rounded-xl bg-brand-600 flex items-center justify-center text-white font-bold text-lg tracking-tight">SI</div>
      <h1 class="text-3xl font-bold text-gray-100">Signal Intelligence</h1>
    </div>
    <p class="text-gray-400 ml-[52px]">Geopolitical event tracking, prediction markets, and narrative analysis.</p>
  </div>

  <div class="grid gap-8 lg:grid-cols-3">
    <div class="lg:col-span-2 space-y-8">
      <section>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-semibold text-gray-200 flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
            Daily Intelligence Brief
          </h2>
          {dailyBrief && (
            <a href={`/briefs/${dailyBrief.date}`} class="text-sm text-brand-400 hover:text-brand-300 transition-colors">
              Read full analysis →
            </a>
          )}
        </div>
        {dailyBrief ? (
          <div class="p-6 rounded-xl bg-surface-raised border border-white/5">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xs font-mono text-gray-500">{dailyBrief.date}</span>
              <span class="text-xs text-gray-600">&middot;</span>
              <span class="text-xs font-mono text-brand-400">{dailyBrief.generated.slice(11,16)} UTC</span>
              {dailyBrief.confidenceFlag !== 'normal' && (
                <span class="text-xs px-2 py-0.5 rounded-full bg-amber-500/20 text-amber-400">{dailyBrief.confidenceFlag}</span>
              )}
            </div>
            <div class="text-sm text-gray-300 leading-relaxed mb-4 space-y-2">
              {dailyBrief.topDevelopments.split('\n').filter(l => l.startsWith('- ')).slice(0, 3).map((line) => (
                <p class="text-sm text-gray-300">{line.replace(/^- \*\*[^*]+\*\*:?\s*/, '').replace(/^- /, '')}</p>
              ))}
            </div>
            <div class="flex items-center gap-4 text-xs text-gray-500">
              <span><span class="text-brand-400">{dailyBrief.eventsAnalysed.length}</span> events analysed</span>
              <span><span class="text-blue-400">{dailyBrief.entitiesReferenced.length}</span> entities referenced</span>
              <span><span class="text-teal-400">{dailyBrief.marketsReferenced.length}</span> markets tracked</span>
            </div>
          </div>
        ) : brief ? (
          <div class="p-6 rounded-xl bg-surface-raised border border-white/5">
            <p class="text-sm text-gray-500 italic">Daily analysis pending — showing latest data collection.</p>
            <div class="flex items-center gap-2 mt-3">
              <span class="text-xs font-mono text-gray-500">{brief.date}</span>
              <span class="text-xs text-gray-600">&middot;</span>
              <span class="text-xs font-mono text-brand-400">{brief.time.length >= 4 ? `${brief.time.slice(0,2)}:${brief.time.slice(2,4)} UTC` : brief.time}</span>
            </div>
          </div>
        ) : (
          <EmptyState message="No briefs available yet" />
        )}
      </section>

      <section>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-semibold text-gray-200 flex items-center gap-2">
            <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            Recent Events
          </h2>
          <a href="/events" class="text-sm text-brand-400 hover:text-brand-300 transition-colors">
            View all →
          </a>
        </div>
        <div class="space-y-3">
          {recentEvents.map((event) => (
            <EventCard event={event} />
          ))}
        </div>
      </section>
    </div>

    <div class="space-y-8">
      <section>
        <h2 class="text-xl font-semibold text-gray-200 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          Market Movers
        </h2>
        <div class="space-y-3">
          {topMarkets.map((market) => (
            <a href={`/markets/${market.question.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`} class="block group">
              <div class="p-4 rounded-xl bg-surface-raised border border-white/5 hover:border-brand-500/30 transition-all duration-200">
                <p class="text-sm text-gray-200 font-medium leading-snug mb-2 group-hover:text-brand-400 transition-colors line-clamp-2">{market.question}</p>
                <div class="flex items-center gap-3">
                  <div class="flex-1 h-1.5 rounded-full bg-gray-800 overflow-hidden">
                    <div class="h-full rounded-full bg-brand-500" style={`width: ${market.yesProbability}%`}></div>
                  </div>
                  <span class="text-xs font-mono text-brand-400 tabular-nums font-medium">{market.yesProbability}%</span>
                </div>
                <p class="text-xs text-gray-500 mt-1.5">Vol: {formatVolume(market.volume)}</p>
              </div>
            </a>
          ))}
        </div>
        <a href="/markets" class="block mt-3 text-sm text-brand-400 hover:text-brand-300 transition-colors text-center">
          View all markets →
        </a>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-gray-200 mb-4">Quick Navigation</h2>
        <div class="grid grid-cols-2 gap-2">
          <a href="/events" class="p-3 rounded-lg bg-surface-raised border border-white/5 hover:border-brand-500/30 text-center transition-colors group">
            <p class="text-2xl font-bold text-brand-400">{events.length}</p>
            <p class="text-xs text-gray-500 group-hover:text-gray-400">Events</p>
          </a>
          <a href="/entities" class="p-3 rounded-lg bg-surface-raised border border-white/5 hover:border-brand-500/30 text-center transition-colors group">
            <p class="text-2xl font-bold text-blue-400">{entities.length}</p>
            <p class="text-xs text-gray-500 group-hover:text-gray-400">Entities</p>
          </a>
          <a href="/narratives" class="p-3 rounded-lg bg-surface-raised border border-white/5 hover:border-brand-500/30 text-center transition-colors group">
            <p class="text-2xl font-bold text-purple-400">{narratives.length}</p>
            <p class="text-xs text-gray-500 group-hover:text-gray-400">Narratives</p>
          </a>
          <a href="/markets" class="p-3 rounded-lg bg-surface-raised border border-white/5 hover:border-brand-500/30 text-center transition-colors group">
            <p class="text-2xl font-bold text-teal-400">{markets.length}</p>
            <p class="text-xs text-gray-500 group-hover:text-gray-400">Markets</p>
          </a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
