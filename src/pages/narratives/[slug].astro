---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimelineSection from '../../components/sections/TimelineSection.astro';
import RelatedEvents from '../../components/cross-links/RelatedEvents.astro';
import EmptyState from '../../components/shared/EmptyState.astro';
import { loadAllNarratives } from '../../data/loader';
import { buildCrossReferences } from '../../data/resolvers';

export function getStaticPaths() {
  const narratives = loadAllNarratives();
  return narratives.map((narrative) => ({
    params: { slug: narrative.slug },
    props: { narrative },
  }));
}

const { narrative } = Astro.props;
const xref = buildCrossReferences();
---

<BaseLayout
  title={narrative.title}
  description={narrative.summary || 'Narrative analysis — Signal Intelligence Wiki'}
  breadcrumbs={[
    { label: 'Narratives', href: '/narratives' },
    { label: narrative.title },
  ]}
>
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-100 leading-tight mb-3">{narrative.title}</h1>
    {narrative.firstObserved && (
      <p class="text-sm text-gray-500">First observed: <span class="font-mono text-gray-400">{narrative.firstObserved}</span></p>
    )}
  </div>

  <div class="space-y-10">
    <section>
      <h2 class="text-lg font-semibold text-gray-200 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Summary
      </h2>
      {narrative.summary ? (
        <div class="p-5 rounded-xl bg-surface-raised border border-white/5 text-sm text-gray-300 leading-relaxed">
          <p>{narrative.summary}</p>
        </div>
      ) : (
        <EmptyState message="Summary not yet available" />
      )}
    </section>

    <section>
      <h2 class="text-lg font-semibold text-gray-200 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        Pushed By
      </h2>
      {narrative.pushedBy.length > 0 ? (
        <div class="space-y-2">
          {narrative.pushedBy.map((actor) => {
            const parts = actor.split('—');
            const name = parts[0].trim();
            const framing = parts.length > 1 ? parts.slice(1).join('—').trim() : null;
            const framingDisplay = framing ? framing.charAt(0).toUpperCase() + framing.slice(1) : null;
            return (
              <div class="p-3 rounded-lg bg-surface-raised border border-white/5">
                <span class="text-sm font-medium text-gray-200">{name}</span>
                {framingDisplay && <p class="text-sm text-gray-400 mt-1">{framingDisplay}</p>}
              </div>
            );
          })}
        </div>
      ) : (
        <EmptyState message="No actors identified yet" />
      )}
    </section>

    <section>
      <h2 class="text-lg font-semibold text-gray-200 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
        Evolution
      </h2>
      {narrative.evolution.length > 0 ? (
        <TimelineSection timeline={narrative.evolution} />
      ) : (
        <EmptyState message="No evolution data yet" />
      )}
    </section>

    <section>
      <h2 class="text-lg font-semibold text-gray-200 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
        Counter-Narratives
      </h2>
      {narrative.counterNarratives.length > 0 ? (
        <div class="space-y-2">
          {narrative.counterNarratives.map((cn) => (
            <div class="p-3 rounded-lg bg-red-500/5 border border-red-500/10">
              <p class="text-sm text-gray-300">{cn}</p>
            </div>
          ))}
        </div>
      ) : (
        <EmptyState message="No counter-narratives identified yet" />
      )}
    </section>

    <section>
      <h2 class="text-lg font-semibold text-gray-200 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        Related Events
      </h2>
      <RelatedEvents slugs={narrative.relatedEvents} xref={xref} emptyMessage="No related events linked yet" />
    </section>
  </div>
</BaseLayout>
