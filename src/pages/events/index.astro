---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventCard from '../../components/cards/EventCard.astro';
import AIAuthoredBadge from '../../components/badges/AIAuthoredBadge.astro';
import { loadAllEvents } from '../../data/loader';

const events = loadAllEvents();

const statuses = [...new Set(events.map((e) => e.status))].filter((s) => s && s.toLowerCase() !== 'unknown').sort();
const theatres = [...new Set(events.map((e) => e.theatre))].filter(Boolean).sort();
const allThemes = [...new Set(events.flatMap((e) => e.themes))].filter((t) => t.trim() !== '').sort();
---

<BaseLayout title="Events" description="Geopolitical events tracked and analysed by Signal Intelligence" footerType="page" footerUpdatedBy="Collector" footerUpdatedAt={events[0]?.lastUpdated || undefined} footerSourceCount={events.length}>
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-100 mb-2">Events</h1>
    <AIAuthoredBadge />
    <p class="text-gray-400">Active geopolitical situations monitored across global theatres.</p>
  </div>

  <div class="flex flex-wrap gap-3 mb-8" id="filters">
    <div class="flex flex-col gap-1">
      <label class="text-xs text-gray-500 uppercase tracking-wider font-medium">Sort by</label>
      <select data-filter="sort" class="bg-surface-raised border border-white/10 rounded-lg px-3 py-2 text-sm text-gray-300 focus:outline-none focus:border-brand-500">
        <option value="freshness">Freshness (newest first)</option>
        <option value="name">Name (A-Z)</option>
      </select>
    </div>
    <div class="flex flex-col gap-1">
      <label class="text-xs text-gray-500 uppercase tracking-wider font-medium">Status</label>
      <select data-filter="status" class="bg-surface-raised border border-white/10 rounded-lg px-3 py-2 text-sm text-gray-300 focus:outline-none focus:border-brand-500">
        <option value="">All statuses</option>
        {statuses.map((s) => <option value={s}>{s}</option>)}
      </select>
    </div>
    <div class="flex flex-col gap-1">
      <label class="text-xs text-gray-500 uppercase tracking-wider font-medium">Theatre</label>
      <select data-filter="theatre" class="bg-surface-raised border border-white/10 rounded-lg px-3 py-2 text-sm text-gray-300 focus:outline-none focus:border-brand-500">
        <option value="">All theatres</option>
        {theatres.map((t) => <option value={t}>{t}</option>)}
      </select>
    </div>
    <div class="flex flex-col gap-1">
      <label class="text-xs text-gray-500 uppercase tracking-wider font-medium">Theme</label>
      <select data-filter="theme" class="bg-surface-raised border border-white/10 rounded-lg px-3 py-2 text-sm text-gray-300 focus:outline-none focus:border-brand-500">
        <option value="">All themes</option>
        {allThemes.map((t) => <option value={t}>{t}</option>)}
      </select>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2" id="event-list">
    {events.map((event) => (
      <div
        class="event-item"
        data-status={event.status}
        data-theatre={event.theatre}
        data-themes={event.themes.join(',')}
        data-updated={event.lastUpdated || ''}
        data-title={event.title.toLowerCase()}
      >
        <EventCard event={event} />
      </div>
    ))}
  </div>

  <p id="no-results" class="hidden text-center text-gray-500 py-12">No events match the selected filters.</p>
</BaseLayout>

<script>
  const filters = document.querySelectorAll('[data-filter]');
  const list = document.getElementById('event-list');
  const items = Array.from(document.querySelectorAll('.event-item'));
  const noResults = document.getElementById('no-results');

  function applyFilters() {
    const active: Record<string, string> = {};
    filters.forEach((el) => {
      const select = el as HTMLSelectElement;
      if (select.dataset.filter === 'sort') return;
      active[select.dataset.filter!] = select.value;
    });

    let visible = 0;
    items.forEach((item) => {
      const el = item as HTMLElement;
      if (el.style.display === 'none') return;
      const status = el.dataset.status || '';
      const theatre = el.dataset.theatre || '';
      const themes = el.dataset.themes || '';

      let show = true;
      if (active.status && status !== active.status) show = false;
      if (active.theatre && theatre !== active.theatre) show = false;
      if (active.theme && !themes.split(',').includes(active.theme)) show = false;

      el.classList.toggle('hidden', !show);
      if (show) visible++;
    });

    if (noResults) noResults.classList.toggle('hidden', visible > 0);
    applySort();
  }

  function applySort() {
    const sortSelect = document.querySelector('[data-filter="sort"]') as HTMLSelectElement;
    const sortBy = sortSelect?.value || 'freshness';
    const sorted = [...items].sort((a, b) => {
      const elA = a as HTMLElement;
      const elB = b as HTMLElement;
      if (sortBy === 'name') {
        return (elA.dataset.title || '').localeCompare(elB.dataset.title || '');
      }
      // freshness: newest first (descending)
      const updA = elA.dataset.updated || '';
      const updB = elB.dataset.updated || '';
      return updB.localeCompare(updA);
    });
    sorted.forEach((el) => list?.appendChild(el));
  }

  filters.forEach((el) => el.addEventListener('change', applyFilters));
  applySort();
</script>
