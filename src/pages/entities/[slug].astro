---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TypeBadge from '../../components/badges/TypeBadge.astro';
import FooterMeta from '../../components/shared/FooterMeta.astro';
import FreshnessBadge from '../../components/badges/FreshnessBadge.astro';
import ObjectivesCard from '../../components/cards/ObjectivesCard.astro';
import TrackRecordSection from '../../components/sections/TrackRecordSection.astro';
import EntityConnections from '../../components/sections/EntityConnections.astro';
import RelatedEvents from '../../components/cross-links/RelatedEvents.astro';
import { loadAllEntities } from '../../data/loader';
import { buildCrossReferences } from '../../data/resolvers';
import { marked } from 'marked';

export function getStaticPaths() {
  const entities = loadAllEntities();
  return entities.map((entity) => ({
    params: { slug: entity.slug },
    props: { entity },
  }));
}

const { entity } = Astro.props;
const xref = buildCrossReferences();
const mentioningEvents = xref.eventsMentioningEntity(entity.slug);
---

<BaseLayout
  title={entity.title}
  description={`${entity.type} — ${entity.affiliations || 'Signal Intelligence entity profile'}`}
  breadcrumbs={[{ label: 'Entities', href: '/entities' }, { label: entity.title }]}
>
  <!-- Header Card -->
  <div class="mb-8 p-6 rounded-card bg-surface border border-[var(--border)]">
    <div class="flex items-start justify-between gap-4 mb-4">
      <h1 class="text-3xl font-medium text-[var(--text-primary)]" style="letter-spacing: -0.704px">
        {entity.title}
      </h1>
      <TypeBadge type={entity.type} />
    </div>
    <div class="flex flex-wrap items-center gap-3 mb-4">
      {entity.affiliations && (
        <span class="text-sm text-[var(--text-muted)]">{entity.affiliations}</span>
      )}
    </div>
    <div class="flex items-center gap-4 text-xs text-[var(--text-faint)]">
      <FreshnessBadge lastUpdated={entity.lastUpdated} />
      <span>·</span>
      <span class="font-mono">{mentioningEvents.length} events referencing</span>
    </div>
  </div>

  <!-- Objectives -->
  <section class="mb-8">
    <ObjectivesCard stated={entity.objectives} inferred={null} />
  </section>

  <!-- Track Record -->
  {entity.claimsAndTrackRecord && (
    <section class="mb-8">
      <TrackRecordSection claims={entity.claimsAndTrackRecord} />
    </section>
  )}

  <!-- Connections (D3 graph placeholder) -->
  <section class="mb-8">
    <EntityConnections
      entitySlug={entity.slug}
      relatedEvents={entity.relatedEntities || []}
      relatedMarkets={entity.relatedMarkets || []}
    />
  </section>

  <!-- Related Events -->
  {mentioningEvents.length > 0 && (
    <section class="mb-8">
      <h2 class="text-lg font-medium text-[var(--text-primary)] mb-4">Mentioned in Events</h2>
      <div class="grid gap-3">
        {mentioningEvents.slice(0, 4).map(event => (
          <a href={`/events/${event.slug}`} class="block p-4 rounded-card bg-surface border border-[var(--border)] hover:border-accent/30 transition-colors">
            <p class="text-sm font-medium text-[var(--text-primary)]">{event.title}</p>
            <p class="text-xs text-[var(--text-faint)] font-mono mt-1">{event.theatre}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <FooterMeta type="entity" updatedBy="Analyst" updatedAt={entity.lastUpdated || undefined} sourceCount={mentioningEvents.length} />
</BaseLayout>
