---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProbabilityChart from '../../components/sections/ProbabilityChart.astro';
import RelatedEvents from '../../components/cross-links/RelatedEvents.astro';
import EmptyState from '../../components/shared/EmptyState.astro';
import FreshnessBadge from '../../components/badges/FreshnessBadge.astro';

import AIAuthoredBadge from '../../components/badges/AIAuthoredBadge.astro';
import EntityCard from '../../components/cards/EntityCard.astro';
import type { WikiEntity } from '../../data/types';
import { loadAllMarkets } from '../../data/loader';
import { buildCrossReferences } from '../../data/resolvers';
import { generateProbabilityChart, formatVolume } from '../../data/svg-chart';

export function getStaticPaths() {
  const markets = loadAllMarkets();
  return markets.map((market) => ({
    params: { slug: market.slug },
    props: { market },
  }));
}

const { market } = Astro.props;
const xref = buildCrossReferences();
const historySvg = generateProbabilityChart(market.history);

const isAwaitingEnrichment = market.context?.toLowerCase().includes('awaiting') || false;

const relatedEntitySlugs = [...new Set(
  market.relatedEvents.flatMap(eventSlug => {
    const event = xref.eventBySlug(eventSlug);
    return event ? event.relatedEntities : [];
  })
)];

const relatedEntities = relatedEntitySlugs
  .map(slug => xref.entityBySlug(slug))
  .filter((e): e is WikiEntity => e !== undefined);
---

<BaseLayout
  title={market.title}
  description={`Current probability: ${market.currentProbability.yes}% Yes — Volume: ${market.volume}`}
  breadcrumbs={[
    { label: 'Markets', href: '/markets' },
    { label: market.title },
  ]}
  footerType="market"
  footerUpdatedBy="Collector"
  footerUpdatedAt={market.history.length > 0 ? market.history[market.history.length - 1].timestamp.slice(0, 10) : null}
  footerSourceCount={relatedEntities.length + market.relatedEvents.length}
>
  <div class="mb-8 p-6 rounded-card bg-surface border border-[var(--border)]">
    <div class="flex items-start justify-between gap-4 mb-4">
      <h1 class="text-3xl font-medium text-[var(--text-primary)] leading-tight" style="letter-spacing: -0.704px">
        {market.title}
      </h1>
      <AIAuthoredBadge />
    </div>
    <div class="flex items-center gap-4 text-xs text-[var(--text-faint)] font-mono">
      {market.lastUpdated && (
        <FreshnessBadge lastUpdated={market.lastUpdated} />
      )}
      <span>·</span>
      <span>{market.volume} volume</span>
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 mb-10">
    <!-- Current Probability hero card -->
    <div class="p-5 rounded-xl bg-gradient-to-br from-brand-900/40 to-brand-800/10 border border-brand-700/40 sm:col-span-2">
      <p class="text-xs text-brand-400 uppercase tracking-wider mb-2">Current Probability</p>
      <div class="flex items-baseline gap-3">
        <span class="text-5xl font-bold font-mono text-gray-100">{market.currentProbability.yes}%</span>
        <span class="text-xl font-mono text-gray-400">Yes</span>
      </div>
      <div class="flex items-baseline gap-3 mt-1">
        <span class="text-2xl font-bold font-mono text-gray-500">{market.currentProbability.no}%</span>
        <span class="text-sm font-mono text-gray-600">No</span>
      </div>
    </div>

    <!-- Volume -->
    <div class="p-4 rounded-xl bg-surface border border-[var(--border)]">
      <p class="text-xs text-[var(--text-faint)] uppercase tracking-wider mb-1">Volume</p>
      <p class="text-xl font-bold font-mono text-[var(--text-primary)]">{market.volume}</p>
    </div>

    <!-- End Date (only if exists) -->
    {market.endDate && (
      <div class="p-4 rounded-xl bg-surface border border-[var(--border)]">
        <p class="text-xs text-[var(--text-faint)] uppercase tracking-wider mb-1">End Date</p>
        <p class="text-xl font-bold font-mono text-[var(--text-primary)]">{new Date(market.endDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</p>
      </div>
    )}

    <!-- Polymarket ID -->
    <div class="p-4 rounded-xl bg-surface border border-[var(--border)]">
      <p class="text-xs text-[var(--text-faint)] uppercase tracking-wider mb-1">Polymarket ID</p>
      <p class="text-sm font-bold font-mono text-[var(--text-primary)] break-all">{market.polymarketId}</p>
    </div>

    <!-- Data Points -->
    <div class="p-4 rounded-xl bg-surface border border-[var(--border)]">
      <p class="text-xs text-[var(--text-faint)] uppercase tracking-wider mb-1">Data Points</p>
      <p class="text-xl font-bold font-mono text-[var(--text-primary)]">{market.history.length}</p>
    </div>
  </div>

  <div class="space-y-10">
    <section>
      <h2 class="text-lg font-semibold text-gray-200 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        Probability Chart
      </h2>
      <ProbabilityChart historySvg={historySvg} currentProbability={market.currentProbability} />
    </section>

    <section>
      <h2 class="text-lg font-semibold text-gray-200 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Context
      </h2>
      {market.context && !isAwaitingEnrichment ? (
        <div class="p-5 rounded-xl bg-surface border border-[var(--border)] text-sm text-[var(--text-secondary)] leading-relaxed">
          <p>{market.context}</p>
        </div>
      ) : (
        <EmptyState message={isAwaitingEnrichment ? 'Awaiting analyst enrichment' : 'No contextual analysis available yet'} />
      )}
    </section>

    <section>
      <h2 class="text-lg font-semibold text-gray-200 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        Related Events
      </h2>
      <RelatedEvents slugs={market.relatedEvents} xref={xref} emptyMessage="No events linked to this market yet" />
    </section>

    {relatedEntities.length > 0 && (
      <section class="mb-10">
        <h2 class="text-lg font-semibold text-[var(--text-primary)] mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Related Entities
        </h2>
        <div class="grid gap-3">
          {relatedEntities.map(entity => (
            <EntityCard entity={entity} />
          ))}
        </div>
      </section>
    )}
  </div>

</BaseLayout>