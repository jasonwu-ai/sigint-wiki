---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProbabilityChart from '../../components/sections/ProbabilityChart.astro';
import RelatedEvents from '../../components/cross-links/RelatedEvents.astro';
import EmptyState from '../../components/shared/EmptyState.astro';
import { loadAllMarkets } from '../../data/loader';
import { buildCrossReferences } from '../../data/resolvers';
import { generateProbabilityChart, formatVolume } from '../../data/svg-chart';

export function getStaticPaths() {
  const markets = loadAllMarkets();
  return markets.map((market) => ({
    params: { slug: market.slug },
    props: { market },
  }));
}

const { market } = Astro.props;
const xref = buildCrossReferences();
const historySvg = generateProbabilityChart(market.history);

const isAwaitingEnrichment = market.context?.toLowerCase().includes('awaiting') || false;
---

<BaseLayout
  title={market.title}
  description={`Current probability: ${market.currentProbability.yes}% Yes — Volume: ${market.volume}`}
  breadcrumbs={[
    { label: 'Markets', href: '/markets' },
    { label: market.title },
  ]}
>
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-100 leading-tight mb-4">{market.title}</h1>
    <div class="grid gap-4 sm:grid-cols-3">
      <div class="p-4 rounded-xl bg-surface-raised border border-white/5">
        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Volume</p>
        <p class="text-xl font-bold font-mono text-gray-100">{market.volume}</p>
      </div>
      <div class="p-4 rounded-xl bg-surface-raised border border-white/5">
        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Polymarket ID</p>
        <p class="text-xl font-bold font-mono text-gray-100">{market.polymarketId}</p>
      </div>
      <div class="p-4 rounded-xl bg-surface-raised border border-white/5">
        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Data Points</p>
        <p class="text-xl font-bold font-mono text-gray-100">{market.history.length}</p>
      </div>
    </div>
  </div>

  <div class="space-y-10">
    <section>
      <h2 class="text-lg font-semibold text-gray-200 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        Probability Chart
      </h2>
      <ProbabilityChart historySvg={historySvg} currentProbability={market.currentProbability} />
    </section>

    <section>
      <h2 class="text-lg font-semibold text-gray-200 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Context
      </h2>
      {market.context && !isAwaitingEnrichment ? (
        <div class="p-5 rounded-xl bg-surface-raised border border-white/5 text-sm text-gray-300 leading-relaxed">
          <p>{market.context}</p>
        </div>
      ) : (
        <EmptyState message={isAwaitingEnrichment ? 'Awaiting analyst enrichment' : 'No contextual analysis available yet'} />
      )}
    </section>

    <section>
      <h2 class="text-lg font-semibold text-gray-200 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        Related Events
      </h2>
      <RelatedEvents slugs={market.relatedEvents} xref={xref} emptyMessage="No events linked to this market yet" />
    </section>
  </div>
</BaseLayout>
