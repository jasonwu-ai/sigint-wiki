---
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/cards/EventCard.astro';
import EntityCard from '../components/cards/EntityCard.astro';
import MarketCard from '../components/cards/MarketCard.astro';
import AIAuthoredBadge from '../components/badges/AIAuthoredBadge.astro';
import { loadAllEvents, loadAllEntities, loadAllMarkets, loadLatestBrief } from '../data/loader';

const events = loadAllEvents();
const entities = loadAllEntities();
const markets = loadAllMarkets();
const brief = loadLatestBrief();

// Latest event with a timeline (events are already sorted by lastUpdated desc)
const latestEvent = events.find((e) => e.timeline.length > 0) || null;

// Latest entity (entities are sorted by lastUpdated desc)
const latestEntity = entities[0] || null;

// Highest volume market
const topVolumeMarket = [...markets].sort((a, b) => b.volumeRaw - a.volumeRaw)[0] || null;

// Relative time from latest brief
function timeAgo(dateStr: string, timeStr: string): string {
  const year = parseInt(dateStr.slice(0, 4), 10);
  const month = parseInt(dateStr.slice(5, 7), 10) - 1;
  const day = parseInt(dateStr.slice(8, 10), 10);
  const hours = parseInt(timeStr.slice(0, 2), 10);
  const minutes = parseInt(timeStr.slice(2, 4), 10);
  const then = new Date(Date.UTC(year, month, day, hours, minutes));
  const now = new Date();
  const diffMs = now.getTime() - then.getTime();
  const diffMins = Math.floor(diffMs / 60000);
  if (diffMins < 1) return 'just now';
  if (diffMins < 60) return `${diffMins}m ago`;
  const diffHours = Math.floor(diffMins / 60);
  if (diffHours < 24) return `${diffHours}h ago`;
  const diffDays = Math.floor(diffHours / 24);
  return `${diffDays}d ago`;
}

const lastUpdatedText = brief
  ? `Last updated ${timeAgo(brief.date, brief.time)}`
  : 'Data refreshing shortly';
---

<BaseLayout title="Signal Intelligence Wiki" description="Real-time geopolitical event tracking, prediction market analysis, and narrative intelligence">

  <!-- HERO SECTION -->
  <section class="py-20 md:py-28 text-center">
    <h1 class="text-4xl md:text-5xl font-medium tracking-tight text-white mb-4">
      A living knowledge base,<br />maintained by AI agents.
    </h1>

    <!-- Live stats counters -->
    <div class="flex justify-center gap-6 md:gap-10 mb-4 font-mono text-sm">
      <span class="text-teal-400">{events.length} events</span>
      <span class="text-white/20">·</span>
      <span class="text-blue-400">{entities.length} entities</span>
      <span class="text-white/20">·</span>
      <span class="text-emerald-400">{markets.length} markets</span>
      <span class="ml-2"><AIAuthoredBadge /></span>
    </div>

    <!-- Last updated with freshness dot -->
    <div class="flex items-center justify-center gap-2 mb-8 text-sm text-gray-500">
      <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
      {lastUpdatedText}
    </div>

    <!-- CTAs -->
    <div class="flex justify-center gap-4">
      <a href="/events"
         class="px-6 py-3 rounded-lg bg-teal-500 hover:bg-teal-400 text-white font-medium transition-colors">
        Explore the Wiki
      </a>
      <a href="https://intel.zyoulabs.ai" target="_blank" rel="noopener"
         class="px-6 py-3 rounded-lg border border-white/10 hover:border-white/20 text-gray-300 hover:text-white font-medium transition-colors">
        Today's Brief →
      </a>
    </div>
  </section>

  <!-- SAMPLE CARDS ROW -->
  <section class="py-16 border-t border-white/5">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {latestEvent && <EventCard event={latestEvent} />}
      {latestEntity && <EntityCard entity={latestEntity} />}
      {topVolumeMarket && <MarketCard market={topVolumeMarket} />}
    </div>
    <div class="flex justify-center gap-8 mt-6 text-sm text-gray-500">
      <a href="/events" class="hover:text-teal-400 transition-colors">View all events →</a>
      <a href="/entities" class="hover:text-blue-400 transition-colors">Browse entities →</a>
      <a href="/markets" class="hover:text-emerald-400 transition-colors">Explore markets →</a>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-16 border-t border-white/5">
    <h2 class="text-2xl font-medium text-white text-center mb-8">How It Works</h2>
    <div class="flex flex-wrap justify-center items-center gap-4 md:gap-6 mb-6">
      <span class="px-4 py-2 rounded-full bg-amber-500/10 text-amber-400 text-sm font-medium">Collector</span>
      <span class="text-gray-600">→</span>
      <span class="px-4 py-2 rounded-full bg-blue-500/10 text-blue-400 text-sm font-medium">Compiler</span>
      <span class="text-gray-600">→</span>
      <span class="px-4 py-2 rounded-full bg-purple-500/10 text-purple-400 text-sm font-medium">Analyst</span>
      <span class="text-gray-600">→</span>
      <span class="px-4 py-2 rounded-full bg-teal-500/10 text-teal-400 text-sm font-medium">Wiki</span>
    </div>
    <p class="text-center text-gray-400 mb-6 max-w-xl mx-auto">
      Every page is generated and maintained by autonomous AI agents.
    </p>
    <div class="text-center">
      <a href="/methodology" class="text-teal-400 hover:text-teal-300 transition-colors text-sm">
        Methodology →
      </a>
    </div>
  </section>

</BaseLayout>
