---
import '../styles/global.css';
import Breadcrumbs from '../components/shared/Breadcrumbs.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  breadcrumbs?: Array<{ label: string; href?: string }>;
}

const {
  title,
  description = 'Signal Intelligence Wiki - Geopolitical event tracking, prediction markets, and narrative analysis',
  ogImage,
  breadcrumbs,
} = Astro.props;

const siteTitle = title === 'Signal Intelligence Wiki' ? title : (title + ' - Signal Intelligence Wiki');
const builtAt = process.env.BUILT_AT
  ? process.env.BUILT_AT
  : new Date().toUTCString();
const resolvedOgImage = ogImage || '/og-default.png';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Signal Intelligence Wiki" />
    <meta property="og:image" content={resolvedOgImage} />
  </head>
  <body class="min-h-screen flex flex-col bg-canvas text-type-body antialiased font-sans">
    <header class="border-b border-[var(--border-subtle)] bg-elevated/80 backdrop-blur-md sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-lg bg-accent flex items-center justify-center text-white font-bold text-sm">SI</div>
          <span class="text-lg font-semibold text-[var(--text-primary)] hidden sm:inline">Signal Intelligence</span>
        </a>
        <nav class="hidden md:flex items-center gap-1">
          <a href="/events" class="px-3 py-2 rounded-lg text-sm font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--border-subtle)] transition-colors">Events</a>
          <a href="/entities" class="px-3 py-2 rounded-lg text-sm font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--border-subtle)] transition-colors">Entities</a>
          <a href="/narratives" class="px-3 py-2 rounded-lg text-sm font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--border-subtle)] transition-colors">Narratives</a>
          <a href="/markets" class="px-3 py-2 rounded-lg text-sm font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--border-subtle)] transition-colors">Markets</a>
          <a href="/methodology" class="px-3 py-2 rounded-lg text-sm font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--border-subtle)] transition-colors">Methodology</a>
        </nav>
        <details class="md:hidden relative">
          <summary class="list-none cursor-pointer p-2 rounded-lg hover:bg-[var(--border-subtle)]">
            <svg class="w-6 h-6 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </summary>
          <div class="absolute right-0 top-full mt-2 w-56 bg-panel border border-[var(--border)] rounded-xl shadow-2xl overflow-hidden z-50">
            <a href="/events" class="block px-4 py-3 text-sm text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--border-subtle)] border-b border-[var(--border-subtle)]">Events</a>
            <a href="/entities" class="block px-4 py-3 text-sm text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--border-subtle)] border-b border-[var(--border-subtle)]">Entities</a>
            <a href="/narratives" class="block px-4 py-3 text-sm text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--border-subtle)] border-b border-[var(--border-subtle)]">Narratives</a>
            <a href="/markets" class="block px-4 py-3 text-sm text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--border-subtle)] border-b border-[var(--border-subtle)]">Markets</a>
            <a href="/methodology" class="block px-4 py-3 text-sm text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--border-subtle)]">Methodology</a>
          </div>
        </details>
      </div>
    </header>

    <main class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      {breadcrumbs && breadcrumbs.length > 0 && <Breadcrumbs items={breadcrumbs} />}
      <slot />
    </main>

    <footer class="border-t border-[var(--border-subtle)] mt-16">
      <div class="max-w-7xl mx-auto px-4 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2 text-sm text-[var(--text-faint)]">
          <div class="w-5 h-5 rounded bg-accent-muted flex items-center justify-center text-accent text-[10px] font-bold">SI</div>
          <span>Signal Intelligence Wiki</span>
        </div>
        <div class="flex items-center gap-4 text-sm text-[var(--text-faint)]">
          <a href="/methodology" class="hover:text-[var(--text-muted)] transition-colors">Methodology</a>
          <span class="text-[var(--border)]">|</span>
          <span>Last updated: {builtAt}</span>
        </div>
      </div>
    </footer>
  </body>
</html>
