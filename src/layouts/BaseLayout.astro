---
import '../styles/global.css';
import Breadcrumbs from '../components/shared/Breadcrumbs.astro';
import FooterMeta from '../components/shared/FooterMeta.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  breadcrumbs?: Array<{ label: string; href?: string }>;
  footerUpdatedBy?: string;
  footerUpdatedAt?: string | null;
  footerSourceCount?: number;
  footerType?: string;
}

const {
  title,
  description = 'Signal Intelligence Wiki - Geopolitical event tracking, prediction markets, and narrative analysis',
  ogImage,
  breadcrumbs,
  footerUpdatedBy,
  footerUpdatedAt,
  footerSourceCount,
  footerType,
} = Astro.props;

const siteTitle = title === 'Signal Intelligence Wiki' ? title : (title + ' - Signal Intelligence Wiki');
const builtAt = process.env.BUILT_AT
  ? process.env.BUILT_AT
  : new Date().toUTCString();
const resolvedOgImage = ogImage || '/og-default.png';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Signal Intelligence Wiki" />
    <meta property="og:image" content={resolvedOgImage} />
  </head>
  <body class="min-h-screen flex flex-col bg-surface text-gray-200 antialiased font-sans">
    <header class="border-b border-white/5 bg-surface-raised/80 backdrop-blur-md sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold text-sm">SI</div>
          <span class="text-lg font-semibold text-gray-100 hidden sm:inline">Signal Intelligence</span>
        </a>
        <nav class="hidden md:flex items-center gap-1">
          <a href="/events" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-gray-200 hover:bg-white/5 transition-colors">Events</a>
          <a href="/entities" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-gray-200 hover:bg-white/5 transition-colors">Entities</a>
          <a href="/narratives" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-gray-200 hover:bg-white/5 transition-colors">Narratives</a>
          <a href="/markets" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-gray-200 hover:bg-white/5 transition-colors">Markets</a>
          <a href="/methodology" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-gray-200 hover:bg-white/5 transition-colors">Methodology</a>
        </nav>
        <details class="md:hidden relative">
          <summary class="list-none cursor-pointer p-2 rounded-lg hover:bg-white/5">
            <svg class="w-6 h-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </summary>
          <div class="absolute right-0 top-full mt-2 w-56 bg-surface-overlay border border-white/10 rounded-xl shadow-2xl overflow-hidden z-50">
            <a href="/events" class="block px-4 py-3 text-sm text-gray-400 hover:text-gray-200 hover:bg-white/5 border-b border-white/5">Events</a>
            <a href="/entities" class="block px-4 py-3 text-sm text-gray-400 hover:text-gray-200 hover:bg-white/5 border-b border-white/5">Entities</a>
            <a href="/narratives" class="block px-4 py-3 text-sm text-gray-400 hover:text-gray-200 hover:bg-white/5 border-b border-white/5">Narratives</a>
            <a href="/markets" class="block px-4 py-3 text-sm text-gray-400 hover:text-gray-200 hover:bg-white/5 border-b border-white/5">Markets</a>
            <a href="/methodology" class="block px-4 py-3 text-sm text-gray-400 hover:text-gray-200 hover:bg-white/5 border-b border-white/5">Methodology</a>
          </div>
        </details>
      </div>
    </header>

    <main class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      {breadcrumbs && breadcrumbs.length > 0 && <Breadcrumbs items={breadcrumbs} />}
      <slot />
    </main>

    <FooterMeta
      type={footerType || 'page'}
      updatedBy={footerUpdatedBy}
      updatedAt={footerUpdatedAt}
      sourceCount={footerSourceCount}
    />
  </body>
</html>
