---
interface Props {
  updatedBy?: string;   // e.g. "Analyst"
  updatedAt?: string | null;   // e.g. "2026-04-15"
  sourceCount?: number;  // number of source events/markets
  type?: 'page' | 'entity' | 'event' | 'market' | 'narrative';
}

const {
  updatedBy,
  updatedAt,
  sourceCount,
  type = 'page',
} = Astro.props;

const agentLabel = updatedBy || 'Collector';
const dateLabel = updatedAt || new Date().toISOString().slice(0, 10);
const sourceLabel = sourceCount ? ` from ${sourceCount} source events` : '';
---

<footer class="border-t border-[var(--border-subtle)] mt-16 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-[var(--text-faint)]">
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 rounded bg-accent-muted flex items-center justify-center">
          <svg class="w-3 h-3 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <span>Generated by AI agents</span>
      </div>
      <div class="flex items-center gap-4 font-mono text-xs">
        <span>Updated by {agentLabel} on {dateLabel}{sourceLabel}</span>
        <span class="text-[var(--border)]">|</span>
        <span class="capitalize">{type} page</span>
      </div>
    </div>
  </div>
</footer>
