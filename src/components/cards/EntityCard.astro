---
import type { WikiEntity } from '../../data/types';
import TypeBadge from '../badges/TypeBadge.astro';

interface Props {
  entity: WikiEntity;
}

const { entity } = Astro.props;
---

<a href={`/entities/${entity.slug}`} class="block group">
  <article class="p-5 rounded-xl bg-surface-raised border border-white/5 hover:border-brand-500/30 hover:bg-surface-overlay transition-all duration-200">
    <div class="flex items-start justify-between gap-3 mb-2">
      <h3 class="text-gray-100 font-semibold text-base leading-snug group-hover:text-brand-400 transition-colors">{entity.title}</h3>
      <TypeBadge type={entity.type} />
    </div>
    {entity.affiliations ? (
      <p class="text-sm text-gray-400">{entity.affiliations}</p>
    ) : (
      <p class="text-sm text-gray-600 italic">Profile pending enrichment</p>
    )}
    {entity.lastUpdated && (
      <p class="text-xs text-gray-600 font-mono mt-2">Updated {entity.lastUpdated}</p>
    )}
  </article>
</a>
