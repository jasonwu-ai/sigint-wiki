---
import type { WikiNarrative } from '../../data/types';
import FreshnessBadge from '../badges/FreshnessBadge.astro';

interface Props {
  narrative: WikiNarrative;
}

const { narrative } = Astro.props;
const previewText = narrative.summary
  ? narrative.summary.length > 140
    ? narrative.summary.slice(0, 140) + '…'
    : narrative.summary
  : null;
---

<a href={`/narratives/${narrative.slug}`} class="block group">
  <article class="p-5 rounded-xl bg-surface-raised border border-white/5 hover:border-brand-500/30 hover:bg-surface-overlay transition-all duration-200">
    <h3 class="text-gray-100 font-semibold text-base leading-snug mb-2 group-hover:text-brand-400 transition-colors">{narrative.title}</h3>
    {previewText ? (
      <p class="text-sm text-gray-400 mb-3 line-clamp-2">{previewText}</p>
    ) : (
      <p class="text-sm text-gray-600 italic mb-3">Summary pending</p>
    )}
    {narrative.pushedBy.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {narrative.pushedBy.slice(0, 3).map((actor) => {
          const name = actor.split('—')[0].trim();
          return (
            <span class="px-2 py-0.5 rounded-full bg-white/5 text-gray-400 text-xs">{name}</span>
          );
        })}
      </div>
    )}
    <div class="mt-2"><FreshnessBadge lastUpdated={narrative.lastUpdated} showLabel={false} /></div>
  </article>
</a>
