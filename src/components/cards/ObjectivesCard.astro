---
interface Props {
  stated?: string | null;
  inferred?: string | null;
}
const { stated, inferred } = Astro.props;
---

<div class="grid md:grid-cols-2 gap-4">
  <div class="p-5 rounded-card bg-surface border border-[var(--border)]">
    <h3 class="text-xs font-mono text-[var(--text-faint)] uppercase tracking-wider mb-3">Stated Objectives</h3>
    {stated ? (
      <div class="text-sm text-[var(--text-body)] prose prose-sm prose-invert" set:html={stated} />
    ) : (
      <p class="text-sm text-[var(--text-faint)] italic">No stated objectives on record.</p>
    )}
  </div>
  <div class="p-5 rounded-card bg-surface border border-[var(--border)]">
    <h3 class="text-xs font-mono text-[var(--text-faint)] uppercase tracking-wider mb-3">Inferred Objectives</h3>
    {inferred ? (
      <div class="text-sm text-[var(--text-body)] prose prose-sm prose-invert" set:html={inferred} />
    ) : (
      <p class="text-sm text-[var(--text-faint)] italic">Inferred objectives pending analyst review.</p>
    )}
  </div>
</div>
